# ============================================================
# TrafficOS — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local no git
# ============================================================

# -------------------------------------------------------
# SUPABASE
# Encontre em: https://supabase.com/dashboard → seu projeto → Settings → API
# -------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# -------------------------------------------------------
# META / FACEBOOK ADS API
# Crie em: https://developers.facebook.com/apps/
# -------------------------------------------------------
NEXT_PUBLIC_META_APP_ID=seu_app_id_aqui
META_APP_SECRET=seu_app_secret_aqui

# URL de callback OAuth do Facebook (deve ser registrada no app do Meta)
# Em produção: https://seudominio.com/api/meta/callback
NEXT_PUBLIC_META_REDIRECT_URI=http://localhost:3000/api/meta/callback

# -------------------------------------------------------
# APP
# -------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -------------------------------------------------------
# CRON (sincronização automática da Meta API)
# Gere uma string aleatória qualquer (ex: openssl rand -hex 32)
# e cadastre o mesmo valor em Settings → Environment Variables na Vercel.
# A Vercel envia esse valor automaticamente no header Authorization
# das chamadas do Cron Job — não precisa configurar nada além disso.
# -------------------------------------------------------
CRON_SECRET=gere_uma_string_aleatoria_aqui
